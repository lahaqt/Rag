// Tailwind延迟加载，不影响首屏渲染（非关键资源）
(function loadTailwind() {
  let placeholder = null;
  
  // 监听head变化，拦截Tailwind创建的style标签
  const observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(mutation) {
      mutation.addedNodes.forEach(function(node) {
        // 检测到Tailwind的style标签
        if (node.tagName === 'STYLE' && node.textContent.includes('tailwind')) {
          // 移动到占位符位置（自定义CSS之前）
          if (placeholder && placeholder.parentNode) {
            placeholder.parentNode.insertBefore(node, placeholder);
          }
          observer.disconnect();
        }
      });
    });
  });
  
  observer.observe(document.head, { childList: true });
  
  function loadScript() {
    let script = document.createElement('script');
    script.src = './js/tailwind@3.4.1_typographytypography@0.5.10.js';
    
    script.onload = function() {
      // Tailwind 脚本加载完成后,创建占位符
      placeholder = document.createElement('script');
      placeholder.id = 'tailwind-placeholder';
      
      // 插入到第一个 link[rel="stylesheet"] 之前
      let firstStyleLink = document.querySelector('link[rel="stylesheet"]');
      if (firstStyleLink && firstStyleLink.parentNode) {
        firstStyleLink.parentNode.insertBefore(placeholder, firstStyleLink);
      } else {
        document.head.appendChild(placeholder);
      }
    };
    
    document.head.appendChild(script);
  }
  
  // 只有当页面存在 .milkdown-editor 时才加载 Tailwind
  if (document.querySelector('.milkdown-editor')) {
    if (window.requestIdleCallback) {
      requestIdleCallback(loadScript);
    } else {
      setTimeout(loadScript, 100);
    }
  }
})();


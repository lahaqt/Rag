function isMilkdown() {
  const hasMilkdown = !!document.querySelector('.milkdown-editor');
  const hasTiptap = !!document.querySelector('.tiptap-wrapper');
  const isQuill = !hasMilkdown && !hasTiptap;

  // 三种预览容器互斥：只隐藏不需要的容器
  const qlSnow = document.querySelector('.ql-snow');
  const milkdownPreview = document.querySelector('.milkdown-preview');
  const tiptapPreview = document.querySelector('.tiptap-preview');

  if (!isQuill && qlSnow) qlSnow.style.display = 'none';
  if (!hasMilkdown && milkdownPreview) milkdownPreview.style.display = 'none';
  if (!hasTiptap && tiptapPreview) tiptapPreview.style.display = 'none';

  // Quill 编辑器不需要暗色模式样式
  if (isQuill) {
    const container = document.querySelector('.quill-editor');
    const titleDom = document.querySelector('.title-mark');
    if (container) container.classList.remove('dark:!bg-[#20242A]');
    if (titleDom) titleDom.classList.remove('dark:!text-slate-300');
  }
}
(function initImagePreview() {
  const milkdownEditor = document.querySelector('.milkdown-editor');
  const tiptapEditor = document.querySelector('.tiptap-wrapper');
  let contentContainer;
  if (tiptapEditor) {
    contentContainer = document.querySelector('.tiptap-preview');
  } else if (milkdownEditor) {
    contentContainer = document.querySelector('.milkdown-preview');
  } else {
    contentContainer = document.querySelector('.content');
  }
  if (!contentContainer) return;
  
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:9999;display:none;justify-content:center;align-items:center;cursor:zoom-out;';
  
  const img = document.createElement('img');
  img.style.cssText = 'max-width:95%;max-height:95vh;object-fit:contain;transition:opacity 0.2s;';
  
  overlay.appendChild(img);
  document.body.appendChild(overlay);
  
  function closePreview() {
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }
  
  overlay.addEventListener('click', closePreview);
  
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.style.display === 'flex') {
      closePreview();
    }
  });
  
  contentContainer.addEventListener('click', function(event) {
    const target = event.target;
    if (target.tagName === 'IMG') {
      img.style.opacity = '0';
      img.src = target.src;
      
      img.onload = function() {
        // 获取原图尺寸
        const naturalWidth = img.naturalWidth;
        const naturalHeight = img.naturalHeight;
        
        // 放大1.5倍，但不超过屏幕95%
        let scale = 1.5;
        const maxWidth = window.innerWidth * 0.95;
        const maxHeight = window.innerHeight * 0.95;
        
        const scaledWidth = naturalWidth * scale;
        const scaledHeight = naturalHeight * scale;
        
        // 如果放大后超出屏幕，按比例缩小
        if (scaledWidth > maxWidth || scaledHeight > maxHeight) {
          const widthRatio = maxWidth / scaledWidth;
          const heightRatio = maxHeight / scaledHeight;
          scale = Math.min(widthRatio, heightRatio) * scale;
        }
        
        img.style.width = naturalWidth + 'px';
        img.style.height = naturalHeight + 'px';
        img.style.transform = 'scale(' + scale + ')';
        img.style.opacity = '1';
      };
      
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
  });
})();


